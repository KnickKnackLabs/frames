#!/usr/bin/env bash
#MISE description="Generate numbered frame images from a sequence"
#USAGE arg "sequence" help="Comma-separated values (e.g. 0,1,0,1,0,1)"
#USAGE flag "--out <dir>" help="Output directory (default: ./frames/seq_<hash>)"
#USAGE flag "--size <size>" help="Image dimensions as WxH (default: 200x200)"
#USAGE flag "--render <script>" help="Script to transform display text (receives: index sequence)"
#USAGE flag "--end <index>" help="Answer index (default: last index in sequence)"
set -eo pipefail

SEQUENCE="${usage_sequence:-$1}"
SIZE="${usage_size:-200x200}"
RENDER_SCRIPT="${usage_render:-}"
WIDTH="${SIZE%x*}"
HEIGHT="${SIZE#*x}"

if [ -z "$SEQUENCE" ]; then
  echo "Error: sequence required (e.g. 0,1,0,1,0,1)"
  exit 1
fi

# Parse sequence into array
IFS=',' read -ra NUMS <<< "$SEQUENCE"

if [ ${#NUMS[@]} -lt 2 ]; then
  echo "Error: sequence must have at least 2 values (frames + answer)"
  exit 1
fi

# Answer index: --end or last index
END_IDX="${usage_end:-$(( ${#NUMS[@]} - 1 ))}"

if [ "$END_IDX" -lt 1 ] || [ "$END_IDX" -ge "${#NUMS[@]}" ]; then
  echo "Error: --end must be between 1 and $((${#NUMS[@]} - 1))"
  exit 1
fi

# Frames are indices 0..end-1, answer is at end
ANSWER="${NUMS[$END_IDX]}"
FRAME_VALS=("${NUMS[@]:0:$END_IDX}")

# Build display values (apply render script if provided)
DISPLAY_VALS=()
for i in "${!FRAME_VALS[@]}"; do
  if [ -n "$RENDER_SCRIPT" ]; then
    DISPLAY_VALS+=("$("$RENDER_SCRIPT" "$i" "$SEQUENCE")")
  else
    DISPLAY_VALS+=("${FRAME_VALS[$i]}")
  fi
done

if [ -n "$RENDER_SCRIPT" ]; then
  DISPLAY_ANSWER=$("$RENDER_SCRIPT" "$END_IDX" "$SEQUENCE")
else
  DISPLAY_ANSWER="$ANSWER"
fi

# Derive output directory (use hash to avoid leaking sequence in dir name)
HASH_INPUT="${SEQUENCE}_end${END_IDX}"
[ -n "$RENDER_SCRIPT" ] && HASH_INPUT="${HASH_INPUT}_$(basename "$RENDER_SCRIPT")"
SEQ_HASH=$(echo -n "$HASH_INPUT" | shasum | cut -c1-8)
OUT_DIR="${usage_out:-./frames/seq_${SEQ_HASH}}"

mkdir -p "$OUT_DIR"

echo "Sequence: ${FRAME_VALS[*]}"
echo "Display: ${DISPLAY_VALS[*]}"
echo "Answer: $DISPLAY_ANSWER"
echo "Frames: ${#FRAME_VALS[@]}"

# Join display values for Python (use | as delimiter to avoid comma conflicts)
DISPLAY_STR=$(IFS='|'; echo "${DISPLAY_VALS[*]}")

# Generate frame images with Pillow
uv run --with pillow python3 - "$DISPLAY_STR" "$OUT_DIR" "$WIDTH" "$HEIGHT" <<'PYTHON'
import sys
from PIL import Image, ImageDraw, ImageFont

values = sys.argv[1].split("|")
out_dir = sys.argv[2]
width, height = int(sys.argv[3]), int(sys.argv[4])

# Auto-scale font: start at half image height, shrink if text is too wide
max_len = max(len(v) for v in values)
font_size = min(width, height) // 2
if max_len > 3:
    font_size = min(font_size, int(width * 0.8 / max_len * 1.5))

# Try platform fonts, fall back to default
font = None
for path in [
    "/System/Library/Fonts/Helvetica.ttc",
    "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf",
    "/usr/share/fonts/TTF/DejaVuSans.ttf",
]:
    try:
        font = ImageFont.truetype(path, font_size)
        break
    except (OSError, IOError):
        continue
if font is None:
    font = ImageFont.load_default()

for i, val in enumerate(values):
    img = Image.new("RGB", (width, height), "white")
    draw = ImageDraw.Draw(img)
    bbox = draw.textbbox((0, 0), val, font=font)
    tw, th = bbox[2] - bbox[0], bbox[3] - bbox[1]
    x = (width - tw) / 2 - bbox[0]
    y = (height - th) / 2 - bbox[1]
    draw.text((x, y), val, fill="black", font=font)
    img.save(f"{out_dir}/frame_{i:03d}.png")
PYTHON

echo "Generated: ${#FRAME_VALS[@]} frames → $OUT_DIR"

# Write metadata
FRAMES_JSON="[]"
for i in "${!FRAME_VALS[@]}"; do
  FILENAME=$(printf "frame_%03d.png" "$i")
  FRAMES_JSON=$(echo "$FRAMES_JSON" | jq \
    --argjson idx "$i" \
    --arg file "$FILENAME" \
    --arg value "${DISPLAY_VALS[$i]}" \
    '. + [{index: $idx, file: $file, value: $value}]')
done

SEQ_JSON=$(printf '%s\n' "${NUMS[@]}" | jq -s '.')

jq -n \
  --argjson sequence "$SEQ_JSON" \
  --argjson frame_count "${#FRAME_VALS[@]}" \
  --arg answer "$DISPLAY_ANSWER" \
  --argjson frames "$FRAMES_JSON" \
  --arg description "$SEQUENCE" \
  '{
    description: $description,
    sequence: $sequence,
    frame_count: $frame_count,
    answer: $answer,
    frames: $frames
  }' > "$OUT_DIR/metadata.json"

echo "Metadata: $OUT_DIR/metadata.json"
