#!/usr/bin/env bash
#MISE description="Run all experiments defined in a JSON file"
#USAGE arg "file" help="Path to experiments JSON file (default: experiments.json)"
set -eo pipefail

EXPERIMENTS_FILE="${usage_file:-${1:-experiments.json}}"

if [ ! -f "$EXPERIMENTS_FILE" ]; then
  echo "Error: experiments file not found: $EXPERIMENTS_FILE"
  exit 1
fi

TOTAL=$(jq length "$EXPERIMENTS_FILE")
echo "Experiments file: $EXPERIMENTS_FILE"
echo "Total experiments: $TOTAL"
echo "==="

# Process each experiment
for i in $(seq 0 $((TOTAL - 1))); do
  NAME=$(jq -r ".[$i].name" "$EXPERIMENTS_FILE")
  TYPE=$(jq -r ".[$i].type // \"sequence\"" "$EXPERIMENTS_FILE")
  MODELS=$(jq -r ".[$i].models // [\"sonnet\"] | .[]" "$EXPERIMENTS_FILE")

  if [ "$TYPE" = "visual" ]; then
    PATTERN=$(jq -r ".[$i].pattern" "$EXPERIMENTS_FILE")
    STEPS=$(jq -r ".[$i].steps" "$EXPERIMENTS_FILE")
    echo ""
    echo "[$((i + 1))/$TOTAL] $NAME: $PATTERN ($STEPS steps)"

    PATTERN_HASH=$(echo -n "${PATTERN}_${STEPS}" | shasum | cut -c1-8)
    FRAMES_DIR="./frames/vis_${PATTERN_HASH}"

    if [ -d "$FRAMES_DIR" ] && [ -f "$FRAMES_DIR/metadata.json" ]; then
      echo "  Frames: reusing $FRAMES_DIR"
    else
      echo "  Frames: generating..."
      mise run generate-visual "$PATTERN" --steps "$STEPS" --out "$FRAMES_DIR" 2>&1 | sed 's/^/  /'
    fi
  else
    SEQUENCE=$(jq -r ".[$i].sequence" "$EXPERIMENTS_FILE")
    echo ""
    echo "[$((i + 1))/$TOTAL] $NAME: $SEQUENCE"

    SEQ_HASH=$(echo -n "$SEQUENCE" | shasum | cut -c1-8)
    FRAMES_DIR="./frames/seq_${SEQ_HASH}"

    if [ -d "$FRAMES_DIR" ] && [ -f "$FRAMES_DIR/metadata.json" ]; then
      echo "  Frames: reusing $FRAMES_DIR"
    else
      echo "  Frames: generating..."
      mise run generate "$SEQUENCE" --out "$FRAMES_DIR" 2>&1 | sed 's/^/  /'
    fi
  fi

  # Run experiment for each model
  for MODEL in $MODELS; do
    RESULTS_DIR="./results/${NAME}_${MODEL}"
    if [ -d "$RESULTS_DIR" ] && [ -f "$RESULTS_DIR/summary.json" ]; then
      echo "  Model $MODEL: skipping (results exist, delete $RESULTS_DIR to re-run)"
    else
      echo "  Model $MODEL: running..."
      mise run experiment "$FRAMES_DIR" --name "$NAME" --model "$MODEL" 2>&1 | sed 's/^/    /'
    fi
  done
done

echo ""
echo "==="
echo "All experiments complete. Run 'mise run report' to see results."
